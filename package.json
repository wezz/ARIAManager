{
  "name": "@wezz/ariamanager",
  "version": "1.1.0",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.umd.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.umd.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "test": "vitest run",
    "check:exports": "publint && attw --pack",
    "prepare": "npm run build",
    "pack": "npm run build",
    "prepublishOnly": "npm run build && publint",
    "trypublish": "npm publish --access public || true",
    "eslint": "eslint --ext .ts,.js ."
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wezz/ARIAManager.git"
  },
  "author": "Wezz Balk <github@wezz.se> (https://github.com/wezz)",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/wezz/ARIAManager/issues"
  },
  "homepage": "https://github.com/wezz/ARIAManager",
  "keywords": [
    "wai-aria",
    "aria",
    "accessibility"
  ],
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.0",
    "@eslint/js": "^9.39.4",
    "@types/node": "^22.14.1",
    "eslint": "^9.39.4",
    "jsdom": "^26.0.0",
    "prettier": "^3.5.3",
    "publint": "^0.3.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.30.1",
    "vite": "^6.4.2",
    "vite-plugin-dts": "^4.5.3",
    "vitest": "^3.2.0"
  }
}
